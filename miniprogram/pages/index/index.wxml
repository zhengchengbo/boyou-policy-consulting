<!-- 博友政策咨询 — 首页 -->
<view class="page-index">
  <!-- 分类筛选 -->
  <view class="filter-bar">
    <view
      wx:for="{{categories}}"
      wx:key="value"
      class="filter-item {{activeCategory === item.value ? 'active' : ''}}"
      data-value="{{item.value}}"
      bind:tap="onCategoryChange"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 政策列表 -->
  <view class="policy-list">
    <block wx:if="{{policyList.length > 0}}">
      <policy-card
        wx:for="{{policyList}}"
        wx:key="id"
        policy="{{item}}"
        bind:tap="onPolicyTap"
        bind:favorite="onToggleFavorite"
      />
      <view wx:if="{{hasMore}}" class="load-more">加载更多...</view>
    </block>

    <view wx:else class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无相关政策</text>
    </view>
  </view>
</view>
