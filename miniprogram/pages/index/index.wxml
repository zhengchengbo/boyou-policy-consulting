<!-- 博友政策咨询 — 极简版首页 -->
<view class="page-index">
  <!-- 搜索区域：未查询时居中，查询后置顶 -->
  <view class="search-area {{hasResult ? 'has-result' : ''}}">
    <!-- 品牌标识（仅初始状态） -->
    <view wx:if="{{!hasResult}}" class="brand">
      <text class="brand-icon">📋</text>
      <text class="brand-name">博友政策咨询</text>
      <text class="brand-slogan">输入企业名称，获取申报计划书</text>
    </view>

    <!-- 搜索框 -->
    <view class="search-box {{inputFocus ? 'focused' : ''}}">
      <input
        class="search-input"
        placeholder="输入企业全称"
        value="{{enterpriseName}}"
        confirm-type="search"
        bind:input="onInput"
        bind:focus="onFocus"
        bind:blur="onBlur"
        bind:confirm="onSearch"
        maxlength="100"
      />
      <text wx:if="{{enterpriseName && !loading}}" class="search-clear" bind:tap="onClear">✕</text>
      <button
        class="search-btn"
        disabled="{{!enterpriseName || loading}}"
        loading="{{loading}}"
        size="mini"
        bind:tap="onSearch"
      >查询</button>
    </view>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{errorMsg}}" class="error-tip">
    <text>{{errorMsg}}</text>
    <text class="retry-link" bind:tap="onSearch">重试</text>
  </view>

  <!-- 结果：申报计划书 -->
  <view wx:if="{{result && !loading && !errorMsg}}" class="report">
    <!-- 报告头部 -->
    <view class="report-header">
      <text class="report-title">📋 政策申报计划书</text>
      <text class="report-enterprise">{{result.enterprise.name}}</text>
      <view class="report-meta">
        <text class="meta-item">匹配 {{result.plan.totalPolicies}} 项政策</text>
        <text class="meta-divider">|</text>
        <text class="meta-item">预估 {{result.plan.totalAmount}}</text>
      </view>
    </view>

    <!-- 政策条目 -->
    <view class="policy-list">
      <view class="policy-card" wx:for="{{result.plan.items}}" wx:key="policyName" wx:for-index="idx">
        <view class="policy-index">{{idx + 1}}</view>
        <view class="policy-body">
          <view class="policy-title-row">
            <text class="policy-name">{{item.policyName}}</text>
            <text wx:if="{{item.amount}}" class="policy-amount">{{item.amount}}</text>
          </view>
          <view class="policy-dept">🏛 {{item.department}}</view>
          <view class="policy-deadline">⏰ 截止：{{item.deadline}}</view>
          <view class="policy-match">✅ {{item.matchReason}}</view>
          <view wx:if="{{item.steps && item.steps.length > 0}}" class="policy-steps">
            <view class="step-item" wx:for="{{item.steps}}" wx:key="*this" wx:for-item="step">
              <text class="step-dot">·</text>
              <text class="step-text">{{step}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部 -->
    <view class="report-footer">
      <text>以上规划基于深圳市现行政策，实际申报以官方最新通知为准</text>
    </view>
  </view>
</view>
