<!-- 政策卡片组件 -->
<view class="policy-card" data-id="{{policy.id}}" bind:tap="onTap">
  <!-- 标题 + 金额 -->
  <view class="card-header">
    <text class="card-title">{{policy.title}}</text>
    <text wx:if="{{policy.amount}}" class="card-amount">{{policy.amount}}</text>
  </view>

  <!-- 标签 -->
  <view class="card-meta">
    <text class="meta-tag">{{policy.category}}</text>
    <text wx:for="{{policy.tags}}" wx:key="*this" class="meta-tag">{{item}}</text>
  </view>

  <!-- 摘要 -->
  <view class="card-summary">{{policy.summary}}</view>

  <!-- 底部信息 -->
  <view class="card-footer">
    <view class="footer-left">
      <text>{{policy.department}}</text>
      <text>截止：{{policy.deadline}}</text>
    </view>
    <text
      class="favorite-btn {{policy.isFavorite ? 'favorited' : ''}}"
      catch:tap="onFavorite"
    >
      {{policy.isFavorite ? '★ 已收藏' : '☆ 收藏'}}
    </text>
  </view>
</view>
