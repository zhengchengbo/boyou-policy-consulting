<!-- 博友政策咨询 — 正式版 -->
<view class="page">
  <view class="hero {{hasResult ? 'compact' : ''}}">
    <view class="hero-inner">
      <!-- 圆形图标 -->
      <view class="icon-circle" wx:if="{{!hasResult}}">
        <image class="icon-img" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%234A90FF' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3E%3Ccircle cx='11' cy='11' r='8'/%3E%3Cpath d='M21 21l-4.35-4.35'/%3E%3C/svg%3E" mode="aspectFit" />
      </view>

      <!-- 标题 -->
      <view class="brand" wx:if="{{!hasResult}}">
        <text class="brand-title">博友政策咨询</text>
        <text class="brand-desc">输入企业名称，一键生成申报规划</text>
      </view>

      <!-- 搜索卡片 -->
      <view class="search-card">
        <view class="search-row">
          <text class="search-icon">🔍</text>
          <input
            class="search-input"
            placeholder="请输入企业全称"
            placeholder-style="color:#b0b0b0"
            value="{{enterpriseName}}"
            confirm-type="search"
            bind:input="onInput"
            bind:confirm="onSearch"
            maxlength="100"
          />
          <text wx:if="{{enterpriseName && !loading}}" class="search-clear" bind:tap="onClear">✕</text>
          <button
            class="search-btn {{!enterpriseName || loading ? 'disabled' : ''}}"
            disabled="{{!enterpriseName || loading}}"
            loading="{{loading}}"
            size="mini"
            bind:tap="onSearch"
          >查询</button>
        </view>
      </view>

      <!-- 加载 -->
      <view wx:if="{{loading}}" class="loading-wrap">
        <view class="loading-bar"></view>
        <text>正在为您匹配可申报政策...</text>
      </view>

      <!-- 错误 -->
      <view wx:if="{{errorMsg && !loading}}" class="error-wrap">
        <text>{{errorMsg}}</text>
        <text class="retry" bind:tap="onSearch">重新查询</text>
      </view>
    </view>
  </view>

  <!-- 结果 -->
  <view wx:if="{{result && !loading && !errorMsg}}" class="result">
    <view class="result-head">
      <text class="rh-title">申报规划书</text>
      <text class="rh-company">{{result.enterprise.name}}</text>
      <view class="rh-stat">
        <text>可申报 <text class="rh-num">{{result.plan.totalPolicies}}</text> 项</text>
        <text class="rh-dot">·</text>
        <text>预估 <text class="rh-num">{{result.plan.totalAmount}}</text></text>
      </view>
    </view>

    <view class="card" wx:for="{{result.plan.items}}" wx:key="policyName" wx:for-index="idx">
      <view class="card-index">{{idx + 1}}</view>
      <view class="card-body">
        <view class="card-head">
          <text class="card-name">{{item.policyName}}</text>
          <text wx:if="{{item.amount}}" class="card-amount">{{item.amount}}</text>
        </view>
        <text class="card-meta">🏛 {{item.department}}  ·  ⏰ {{item.deadline}}</text>
        <text class="card-match">✅ {{item.matchReason}}</text>
        <view wx:if="{{item.steps && item.steps.length}}" class="card-steps">
          <text wx:for="{{item.steps}}" wx:key="*this" wx:for-item="s" class="step">· {{s}}</text>
        </view>
      </view>
    </view>
    <view class="footer">以上基于深圳市现行政策，实际以官方最新通知为准</view>
  </view>
</view>
