<!-- 博友政策咨询 — 百度风格搜索 -->
<view class="page">
  <!-- 搜索区（始终大屏居中） -->
  <view class="hero {{hasResult ? 'compact' : ''}}">
    <view class="hero-inner">
      <!-- 品牌 -->
      <view class="logo-area" wx:if="{{!hasResult}}">
        <text class="logo-text">博友</text>
        <text class="logo-sub">企业政策红利挖掘者</text>
      </view>

      <!-- 搜索框 -->
      <view class="search-wrap">
        <view class="search-box {{inputFocus ? 'focus' : ''}}">
          <input
            class="search-input"
            placeholder="输入企业名称，获取申报计划"
            placeholder-style="color:#b0b0b0;font-size:16px"
            value="{{enterpriseName}}"
            confirm-type="search"
            bind:input="onInput"
            bind:focus="onFocus"
            bind:blur="onBlur"
            bind:confirm="onSearch"
            maxlength="100"
          />
          <view wx:if="{{enterpriseName && !loading}}" class="search-clear" bind:tap="onClear">
            <text>✕</text>
          </view>
          <button
            class="search-btn {{!enterpriseName || loading ? 'disabled' : ''}}"
            disabled="{{!enterpriseName || loading}}"
            loading="{{loading}}"
            bind:tap="onSearch"
          >{{loading ? '' : '查询'}}</button>
        </view>
      </view>

      <!-- 加载 -->
      <view wx:if="{{loading}}" class="loading-wrap">
        <view class="loading-bar"></view>
        <text>正在分析企业信息...</text>
      </view>

      <!-- 错误 -->
      <view wx:if="{{errorMsg && !loading}}" class="error-wrap">
        <text>{{errorMsg}}</text>
        <text class="retry" bind:tap="onSearch">重新查询</text>
      </view>
    </view>
  </view>

  <!-- 结果 -->
  <view wx:if="{{result && !loading && !errorMsg}}" class="result-area">
    <!-- 计划书头部 -->
    <view class="result-head">
      <text class="rh-title">📋 申报计划书</text>
      <text class="rh-company">{{result.enterprise.name}}</text>
      <view class="rh-stat">
        <text>可申报 {{result.plan.totalPolicies}} 项</text>
        <text class="rh-dot">·</text>
        <text>预估 {{result.plan.totalAmount}}</text>
      </view>
    </view>

    <!-- 政策列表 -->
    <view class="card" wx:for="{{result.plan.items}}" wx:key="policyName" wx:for-index="idx">
      <view class="card-left">{{idx + 1}}</view>
      <view class="card-body">
        <view class="card-head">
          <text class="card-name">{{item.policyName}}</text>
          <text wx:if="{{item.amount}}" class="card-money">{{item.amount}}</text>
        </view>
        <text class="card-line">🏛 {{item.department}}</text>
        <text class="card-line">⏰ {{item.deadline}}</text>
        <text class="card-tag">✅ {{item.matchReason}}</text>
        <view wx:if="{{item.steps && item.steps.length}}" class="card-steps">
          <text wx:for="{{item.steps}}" wx:key="*this" wx:for-item="s" class="step">· {{s}}</text>
        </view>
      </view>
    </view>

    <view class="footer">以上基于深圳市现行政策，实际以官方最新通知为准</view>
  </view>
</view>
