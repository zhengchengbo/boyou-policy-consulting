<!-- 博友政策咨询 — 简洁工具风 -->
<view class="page">
  <view class="hero {{hasResult ? 'pinned' : ''}}">
    <view class="hero-inner">
      <!-- 图标：用logo渐变色 -->
      <view class="logo-circle" wx:if="{{!hasResult}}">
        <text class="logo-letter">B</text>
      </view>

      <view class="title-group" wx:if="{{!hasResult}}">
        <text class="title-main">博友政策咨询</text>
        <text class="title-sub">输入企业名称，生成申报规划</text>
      </view>

      <!-- 搜索框 -->
      <view class="search-card">
        <view class="search-body">
          <text class="search-icon">🔍</text>
          <input
            class="search-input"
            placeholder="请输入企业全称"
            placeholder-style="color:#b5b5b5"
            value="{{enterpriseName}}"
            confirm-type="search"
            bind:input="onInput"
            bind:confirm="onSearch"
            maxlength="100"
          />
          <text wx:if="{{enterpriseName && !loading}}" class="search-clear" bind:tap="onClear">✕</text>
        </view>
        <button
          class="search-btn {{!enterpriseName || loading ? 'disabled' : ''}}"
          disabled="{{!enterpriseName || loading}}"
          loading="{{loading}}"
          bind:tap="onSearch"
        >查询</button>
      </view>

      <view wx:if="{{loading}}" class="loading-wrap">
        <view class="loading-bar"></view>
        <text>匹配政策中...</text>
      </view>

      <view wx:if="{{errorMsg && !loading}}" class="error-wrap">
        <text>{{errorMsg}}</text>
        <text class="retry" bind:tap="onSearch">重试</text>
      </view>
    </view>
  </view>

  <!-- 结果 -->
  <view wx:if="{{result && !loading && !errorMsg}}" class="result">
    <view class="result-head">
      <text class="rh-title">申报规划书</text>
      <text class="rh-company">{{result.enterprise.name}}</text>
      <view class="rh-stats">
        <text>可申报 <text class="rh-num">{{result.plan.totalPolicies}}</text> 项</text>
        <text class="rh-dot">·</text>
        <text>预估 <text class="rh-num">{{result.plan.totalAmount}}</text></text>
      </view>
    </view>

    <view class="card" wx:for="{{result.plan.items}}" wx:key="policyName" wx:for-index="idx">
      <view class="card-idx">{{idx + 1}}</view>
      <view class="card-body">
        <view class="card-head">
          <text class="card-name">{{item.policyName}}</text>
          <text wx:if="{{item.amount}}" class="card-amt">{{item.amount}}</text>
        </view>
        <text class="card-line">🏛 {{item.department}} · ⏰ {{item.deadline}}</text>
        <text class="card-tag">✅ {{item.matchReason}}</text>
        <view wx:if="{{item.steps && item.steps.length}}" class="card-steps">
          <text wx:for="{{item.steps}}" wx:key="*this" wx:for-item="s" class="step">· {{s}}</text>
        </view>
      </view>
    </view>
    <view class="footer">以上基于深圳市现行政策，实际以官方最新通知为准</view>
  </view>
</view>
